{
  "name": "ayd-platform",
  "private": true,
  "version": "1.0.0",
  "description": "African Youth Database — Continental Data Intelligence Platform",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:web": "pnpm --filter @ayd/web dev",
    "dev:api": "pnpm --filter @ayd/api dev",
    "build": "pnpm run --parallel build",
    "build:web": "pnpm --filter @ayd/web build",
    "build:api": "pnpm --filter @ayd/api build",
    "lint": "pnpm run --parallel lint",
    "db:generate": "pnpm --filter @ayd/database generate",
    "db:push": "pnpm --filter @ayd/database push",
    "db:migrate": "pnpm --filter @ayd/database migrate",
    "db:seed": "pnpm --filter @ayd/api seed",
    "db:studio": "pnpm --filter @ayd/database studio",
    "clean": "pnpm run --parallel clean",
    "import:worldbank": "tsx scripts/import-worldbank.ts",
    "import:csv": "tsx scripts/import-csv.ts",
    "import:ilo": "tsx scripts/import-ilo.ts",
    "seed:policies": "tsx scripts/seed-policies.ts",
    "seed:experts": "tsx scripts/seed-experts.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "@prisma/client": "^5.19.1",
    "prisma": "^5.19.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
