# ============================================================
# AYD Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values

# ---- Database ----
DATABASE_URL="postgresql://ayd_user:ayd_password@localhost:5432/ayd_database?schema=public"

# ---- API Server ----
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ---- Frontend ----
VITE_API_URL=/api

# ---- Auth ----
# IMPORTANT: Change this to a secure random string in production (min 32 chars)
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRES_IN=24h

# ---- Default Admin (dev only — change password in production!) ----
# Email: admin@africanyouthdatabase.org
# Password: AYD@Admin2026!

# ---- AI / LLM (optional — rule-based fallback if not set) ----
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514

# ---- CORS ----
CORS_ORIGIN=http://localhost:8080
