# ============================================================
# AYD Platform — Production Environment Variables
# ============================================================

# Database
DATABASE_URL=postgresql://user:password@host:5432/ayd_production

# Auth
JWT_SECRET=generate-a-64-char-random-string-here

# AI (optional — rule-based fallback if not set)
ANTHROPIC_API_KEY=sk-ant-your-key
AI_MODEL=claude-sonnet-4-20250514

# Server
API_PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://africanyouthdatabase.org,https://www.africanyouthdatabase.org

# Frontend
VITE_API_URL=https://api.africanyouthdatabase.org/api
