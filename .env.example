# ============================================================
# AYD Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values

# ---- Database ----
DATABASE_URL="postgresql://ayd_user:ayd_password@localhost:5432/ayd_database?schema=public"

# ---- API Server ----
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ---- Frontend ----
VITE_API_URL=/api

# ---- Auth (Supabase) ----
# Supabase owns authentication. The backend ONLY validates JWTs Supabase issues;
# it never creates or signs tokens of its own.
#
# Get this from: Supabase dashboard → Project Settings → API → JWT Secret
# Must match the project the frontend is signing in against (VITE_SUPABASE_URL).
# Without this, every authenticated request returns 401 and JIT user provisioning
# silently fails.
SUPABASE_JWT_SECRET=your-supabase-project-jwt-secret

# Frontend — Supabase client config
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---- AI / LLM (optional — rule-based fallback if not set) ----
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514

# ---- Resend (Email) ----
RESEND_API_KEY=re_...
FROM_EMAIL=African Youth Observatory <noreply@pacsda.org>
ADMIN_EMAIL=admin@africanyouthdatabase.org
FRONTEND_URL=http://localhost:8080

# ---- CORS ----
CORS_ORIGIN=http://localhost:8080

# ---- CMS / Cloudflare R2 (image uploads) ----
# Create an R2 bucket + API token at https://dash.cloudflare.com → R2
# Enable public access on the bucket and paste the public URL below.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ayd-cms
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
