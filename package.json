{
  "name": "ayd-platform",
  "private": true,
  "version": "1.0.0",
  "description": "African Youth Database — Continental Data Intelligence Platform",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd apps/api && npm run dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:api": "cd apps/api && npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist",
    "pages:deploy": "wrangler pages deploy dist",
    "db:generate": "cd packages/database && npx prisma generate",
    "db:push": "cd packages/database && npx prisma db push",
    "db:migrate": "cd packages/database && npx prisma migrate deploy",
    "db:seed": "cd apps/api && npx ts-node -r tsconfig-paths/register src/seed.ts",
    "db:studio": "cd packages/database && npx prisma studio",
    "import:worldbank": "tsx scripts/import-worldbank.ts",
    "import:csv": "tsx scripts/import-csv.ts",
    "import:ilo": "tsx scripts/import-ilo.ts",
    "import:ayims": "tsx scripts/import-ayims.ts",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "seed:policies": "tsx scripts/seed-policies.ts",
    "seed:experts": "tsx scripts/seed-experts.ts",
    "import:ayc-scorecard": "tsx scripts/import-ayc-scorecard.ts",
    "compute:youth-index": "tsx scripts/compute-youth-index.ts",
    "setup": "bash scripts/setup.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-hover-card": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-query": "^5.56.2",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@types/dompurify": "^3.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
