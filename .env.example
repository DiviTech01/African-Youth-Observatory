# ============================================================
# AYD Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values

# ---- Database ----
DATABASE_URL="postgresql://ayd_user:ayd_password@localhost:5432/ayd_database?schema=public"

# ---- API Server ----
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ---- Frontend ----
VITE_API_URL=http://localhost:3001/api

# ---- Auth (future) ----
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# ---- CORS ----
CORS_ORIGIN=http://localhost:5173
